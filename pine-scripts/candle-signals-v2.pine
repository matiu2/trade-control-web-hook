//@version=6
indicator("Candle Signals", shorttitle="Candle Signals", overlay=true, max_labels_count=500)
// Combined detector for: Pinbars, Tweezers, Double Tweezers, Regular Engulfers, Floating Engulfers
// Outputs unified bullish/bearish signals
//
// v2.2: collapses to 2 alertconditions ("Long Pattern", "Short Pattern") and
// latches the most-recent signal's geometry + classifier metadata onto
// persistent plot() series so the alertconditions can embed them in the
// alert message via {{plot("signal_high")}} etc.
//
// Wire-format vars latched at signal time:
//   signal_high, signal_low, signal_range  — geometry of the signal
//     (spans 1 bar for pinbar/floating, 2 bars for tweezer/regular,
//     3 bars for double_tweezer).
//   signal_start_time                      — ms epoch of the *earliest*
//     bar that's part of the signal. Renamed from pattern_time to
//     disambiguate from current-bar `time`.
//   signal_kind  — float-encoded enum:
//     1 = pinbar, 2 = tweezer, 3 = regular_engulfer,
//     4 = floating_engulfer, 5 = double_tweezer.
//   golden       — 1.0 if signal_range >= ATR at signal time, else 0.0.
//   atr          — ATR value at signal time.
//   signal_confirmed — 1.0 once a confirming push has validated the
//     latched signal within `confirm_bars`, 0.0 otherwise. Resets to
//     0.0 every time a fresh signal overwrites the latch.
//   recent_high, recent_low — extreme of the `sl_lookback` bars
//     preceding the signal, a robust SL anchor.
//
// v2.3: adds next_candle_timestamp_1..5 — the expected close timestamps
//   (ms epoch) of the next 1..5 bars on this timeframe, computed via
//   time_close(timeframe.period, bars_back=-N) so they respect the
//   symbol's session calendar (weekend / session-break aware). The
//   worker indexes this menu with the signed `expiry_bars` to cancel a
//   resting entry order N bars after placement. na on non-time charts.
//
// v2.4: adds an "Every Bar Close" alertcondition firing every closed bar
//   with only TradingView built-ins (close/high/low/time, no plots). It is
//   the per-bar heartbeat that M/W (double-top / double-bottom) reversal
//   enter intents bind to — those trades carry no chart-side pattern
//   detection; tv-arm bakes the path geometry into the signed intent and the
//   worker recomputes the stop-entry/SL/TP each bar close. H&S is unaffected
//   (it keeps firing on Long/Short Pattern). Requires a manual republish of
//   the study after pulling this version.
//
// v2.5: adds `open={{open}}` to the "Every Bar Close" message. `open` is a
//   TradingView built-in (no plot-index risk), letting the worker compute
//   candle-body extremes (max(open,close) / min(open,close)) for M/W
//   rogue-wick handling and dynamic neckline revision. Backward-compatible:
//   the worker treats `open` as optional, so a chart still running v2.4
//   keeps working (those bars just can't drive body-based logic). Requires a
//   manual republish to start sending `open`.
//
// Single alert per direction; the worker-side Rhai engine reads the
// shell vars to decide whether to act (golden filter, kind filter,
// confirmation requirement, candle-size override, etc.).

// =============================================================================
// SIGNAL STATE RULES
// =============================================================================
// 1. Every detected signal starts in the pending state when it prints.
// 2. If price trades above the high of a bearish signal, it becomes invalid.
// 3. If price trades below the low of a bullish signal, it becomes invalid.
// 4. A bullish pending signal becomes valid when price pushes above its high within `confirm_bars`.
// 5. A bearish pending signal becomes valid when price pushes below its low within `confirm_bars`.
// 6. Any pending signal that neither validates nor invalidates within `confirm_bars` becomes invalid.
// 7. An opposing-direction signal printing inside the `confirm_bars` window
//    invalidates the original (this can flip a previously-VALID signal back
//    to INVALID — confirmation only counts if no opposer printed in-window).
//    Exception: if the original is golden and the opposer is NOT golden, the
//    opposer is ignored and the original stands. All other combos
//    (gold-vs-gold, non-gold-vs-gold, non-gold-vs-non-gold) invalidate.

// ===== Inputs ================================================================
show_symbols = input.bool(true, "Show Symbols")
max_signals = input.int(100, "Max Signals to Track", minval=10, maxval=500, tooltip="Limits memory usage by only tracking recent signals")

// Pattern toggles
detect_pinbars = input.bool(true, "Detect Pinbars")
detect_tweezers = input.bool(true, "Detect Tweezers")
detect_double_tweezers = input.bool(true, "Detect Double Tweezers", tooltip="3 consecutive bars in the same direction all qualify as pinbar-ish. Treated as a single signal kind; priority over plain tweezer.")
detect_regular_engulfers = input.bool(true, "Detect Regular Engulfers")
detect_floating_engulfers = input.bool(true, "Detect Floating Engulfers")

// Size filter
show_golden_candles = input.bool(true, "Show Golden Candles", tooltip="Show signals where candle size >= ATR")
show_small_candles = input.bool(false, "Show Small Candles", tooltip="Show signals where candle size < ATR")

// State visibility
hide_pending = input.bool(false, "Hide Pending Signals")
hide_invalid = input.bool(true, "Hide Invalid Signals")

// Confirmation window — how many bars after a pending signal prints we still
// accept a confirming push above/below its extreme. Used by both the visual
// state machine and the Long/Short Pattern alertconditions (signal_confirmed
// flips to 1.0 inside this window).
confirm_bars = input.int(2, "Confirmation Bars", minval=1, maxval=10, tooltip="Bars after signal print within which a confirming push validates the signal.")

// SL lookback — how many prior bars to scan when reporting recent_high / recent_low
// for SL anchoring. Worker-side scripts can use these as stop-loss reference levels.
sl_lookback = input.int(5, "SL Lookback Bars", minval=1, maxval=200, tooltip="Window of prior bars whose extreme is reported as recent_high / recent_low for stop-loss anchoring.")

// Tweezer similarity threshold
similarity_pct = input.float(20.0, "Tweezer High/Low Similarity (%)", minval=0.0, maxval=100.0, step=0.1)

// Colors and shapes
bullish_color = input.color(color.new(color.blue, 0), "Bullish Color")
bullish_shape = input.string("Triangle", "Bullish Pending Shape", options=["Arrow", "Triangle", "Diamond", "Square", "Circle", "Cross", "Label"])
bearish_color = input.color(color.new(color.orange, 0), "Bearish Color")
bearish_shape = input.string("Triangle", "Bearish Pending Shape", options=["Arrow", "Triangle", "Diamond", "Square", "Circle", "Cross", "Label"])

// ===== Constants =============================================================
const int STATE_PENDING = 0
const int STATE_VALID = 1
const int STATE_INVALID = 2

// signal_kind float encoding — keep in sync with Rust SignalKind serde adapter.
const float KIND_PINBAR            = 1.0
const float KIND_TWEEZER           = 2.0
const float KIND_REGULAR_ENGULFER  = 3.0
const float KIND_FLOATING_ENGULFER = 4.0
const float KIND_DOUBLE_TWEEZER    = 5.0

// ===== Helper Functions ======================================================
resolve_label_style(string option, bool is_bullish) =>
    switch option
        "Arrow" => is_bullish ? label.style_arrowup : label.style_arrowdown
        "Triangle" => is_bullish ? label.style_triangleup : label.style_triangledown
        "Diamond" => label.style_diamond
        "Square" => label.style_square
        "Circle" => label.style_circle
        "Cross" => label.style_cross
        "Label" => is_bullish ? label.style_label_up : label.style_label_down
        => is_bullish ? label.style_triangleup : label.style_triangledown


bullish_pending_style = resolve_label_style(bullish_shape, true)
bearish_pending_style = resolve_label_style(bearish_shape, false)

f_apply_label_style(label sig_label, bool is_bullish, int state, bool is_golden) =>
    if not na(sig_label)
        // Shape: pending = chosen shape, valid = triangle, invalid = cross
        string lbl_style = switch state
            STATE_VALID   => is_bullish ? label.style_triangleup : label.style_triangledown
            STATE_INVALID => label.style_cross
            => is_bullish ? bullish_pending_style : bearish_pending_style
        label.set_style(sig_label, lbl_style)

        // Size: golden = small; everything else = tiny
        string base_size = is_golden ? size.small : size.tiny
        string lbl_size = base_size
        label.set_size(sig_label, lbl_size)

        // Color: valid golden = full opacity; valid small + pending = 50%; invalid = gray
        color base_col = is_bullish ? bullish_color : bearish_color
        color fill = switch state
            STATE_VALID   => is_golden ? base_col : color.new(base_col, 50)
            STATE_INVALID => color.new(color.gray, 60)
            => color.new(base_col, 50)
        label.set_color(sig_label, fill)

        // Visibility
        bool hidden = (state == STATE_PENDING and hide_pending) or (state == STATE_INVALID and hide_invalid)
        label.set_size(sig_label, hidden ? size.auto : lbl_size)
        label.set_color(sig_label, hidden ? color.new(color.white, 100) : fill)

f_create_label(int bar_idx, float price, bool is_bullish, bool is_golden) =>
    label lbl = na
    if show_symbols
        string base_size = is_golden ? size.small : size.tiny
        string init_style = is_bullish ? bullish_pending_style : bearish_pending_style
        lbl := label.new(bar_idx, price, "", xloc=xloc.bar_index, yloc=yloc.price, style=init_style, size=base_size)
    lbl

// ===== ATR Calculation with Timeframe-Based Length ===========================
f_get_atr_length() =>
    int tf_mins = timeframe.in_seconds() / 60
    if tf_mins <= 15
        96  // 15m: 24 * 4 = 96 (one day)
    else if tf_mins <= 60
        24  // 1h: 24 (one day)
    else if tf_mins <= 240
        36  // 4h: 6 * 6 = 36 (6 days a week, 6 candles a day)
    else if tf_mins <= 1440
        24  // 1d: 6 * 4 = 24 (6 days a week, 4 weeks a month)
    else if tf_mins <= 10080
        52  // 1w: 52 (one year)
    else
        24  // 1m: 24 (two years)

atr_length = f_get_atr_length()
atr_value = ta.atr(atr_length)

// ===== Common Calculations ===================================================
candle_range = high - low
body_size = math.abs(close - open)
body_top = math.max(open, close)
body_bottom = math.min(open, close)
upper_wick = high - body_top
lower_wick = body_bottom - low

top_25 = high - candle_range * 0.25
bottom_25 = low + candle_range * 0.25
midpoint = low + candle_range * 0.5

valid_candle = candle_range > 0 and body_size > 0

// Close position within candle range (0 = at low, 1 = at high)
close_position = candle_range > 0 ? (close - low) / candle_range : na
close_in_top_25 = candle_range > 0 and close_position >= 0.75
close_in_bottom_25 = candle_range > 0 and close_position <= 0.25

// Previous candle data
prev_open = open[1]
prev_close = close[1]
prev_high = high[1]
prev_low = low[1]
prev_candle_range = high[1] - low[1]

prev_is_bullish = prev_close > prev_open
prev_is_bearish = prev_close < prev_open
curr_is_bullish = close > open
curr_is_bearish = close < open

valid_prev = not na(prev_open) and not na(prev_close) and not na(prev_high) and not na(prev_low)
valid_inputs = valid_prev and valid_candle

// ===== Pinbar Detection ======================================================
bullish_pinbar = detect_pinbars and valid_candle and body_top >= top_25 and body_bottom >= midpoint and lower_wick >= candle_range * 0.5 and low < low[1]
bearish_pinbar = detect_pinbars and valid_candle and body_bottom <= bottom_25 and body_top <= midpoint and upper_wick >= candle_range * 0.5 and high > high[1]

// ===== Tweezer Detection =====================================================
const float TWEEZER_WICK_THRESHOLD = 0.35
prev_bullish_pinbar = valid_candle[1] and body_top[1] >= top_25[1] and body_bottom[1] >= midpoint[1] and lower_wick[1] >= candle_range[1] * TWEEZER_WICK_THRESHOLD
prev_bearish_pinbar = valid_candle[1] and body_bottom[1] <= bottom_25[1] and body_top[1] <= midpoint[1] and upper_wick[1] >= candle_range[1] * TWEEZER_WICK_THRESHOLD

// Bar N-2 (for double-tweezer): the "previous-previous" pinbar test.
prev2_bullish_pinbar = valid_candle[2] and body_top[2] >= top_25[2] and body_bottom[2] >= midpoint[2] and lower_wick[2] >= candle_range[2] * TWEEZER_WICK_THRESHOLD
prev2_bearish_pinbar = valid_candle[2] and body_bottom[2] <= bottom_25[2] and body_top[2] <= midpoint[2] and upper_wick[2] >= candle_range[2] * TWEEZER_WICK_THRESHOLD

curr_bullish_pinbar_tweezer = valid_candle and body_top >= top_25 and body_bottom >= midpoint and lower_wick >= candle_range * TWEEZER_WICK_THRESHOLD
curr_bearish_pinbar_tweezer = valid_candle and body_bottom <= bottom_25 and body_top <= midpoint and upper_wick >= candle_range * TWEEZER_WICK_THRESHOLD

has_prev_bar = bar_index > 0
pair_range = has_prev_bar ? math.max(candle_range, prev_candle_range) : na
has_pair_data = has_prev_bar and pair_range > 0
range_similarity_threshold = has_pair_data ? pair_range * similarity_pct * 0.01 : na
highs_close = has_pair_data ? math.abs(high - prev_high) <= range_similarity_threshold : false
lows_close = has_pair_data ? math.abs(low - prev_low) <= range_similarity_threshold : false

// Triple-bar similarity for double-tweezer: highs and lows of all 3 bars
// (N, N-1, N-2) must lie within similarity_pct of the largest range.
has_triple_bar = bar_index > 1
prev2_candle_range = high[2] - low[2]
triple_range = has_triple_bar ? math.max(candle_range, prev_candle_range, prev2_candle_range) : na
has_triple_data = has_triple_bar and triple_range > 0
triple_similarity_threshold = has_triple_data ? triple_range * similarity_pct * 0.01 : na
triple_highs_close = has_triple_data ? math.abs(high - prev_high) <= triple_similarity_threshold and math.abs(prev_high - high[2]) <= triple_similarity_threshold : false
triple_lows_close = has_triple_data ? math.abs(low - prev_low) <= triple_similarity_threshold and math.abs(prev_low - low[2]) <= triple_similarity_threshold : false

confirmed_bar = barstate.isconfirmed
valid_pair = confirmed_bar and has_pair_data and valid_candle[1] and highs_close and lows_close
valid_triple = confirmed_bar and has_triple_data and valid_candle[1] and valid_candle[2] and triple_highs_close and triple_lows_close

bullish_double_tweezer = detect_double_tweezers and valid_triple and curr_bullish_pinbar_tweezer and prev_bullish_pinbar and prev2_bullish_pinbar
bearish_double_tweezer = detect_double_tweezers and valid_triple and curr_bearish_pinbar_tweezer and prev_bearish_pinbar and prev2_bearish_pinbar

bullish_tweezer = detect_tweezers and valid_pair and curr_bullish_pinbar_tweezer and prev_bullish_pinbar and not bullish_double_tweezer
bearish_tweezer = detect_tweezers and valid_pair and curr_bearish_pinbar_tweezer and prev_bearish_pinbar and not bearish_double_tweezer

// ===== Regular Engulfer Detection ============================================
bullish_regular = detect_regular_engulfers and valid_inputs and prev_is_bearish and curr_is_bullish and open <= prev_close and close > prev_high and close_in_top_25
bearish_regular = detect_regular_engulfers and valid_inputs and prev_is_bullish and curr_is_bearish and open >= prev_close and close < prev_low and close_in_bottom_25

// ===== Floating Engulfer Detection ===========================================
bullish_floating = detect_floating_engulfers and valid_inputs and prev_is_bullish and curr_is_bullish and close > prev_high and close_in_top_25
bearish_floating = detect_floating_engulfers and valid_inputs and prev_is_bearish and curr_is_bearish and close < prev_low and close_in_bottom_25

// ===== Combined Signals ======================================================
is_golden_candle = candle_range >= atr_value
show_this_candle = (is_golden_candle and show_golden_candles) or (not is_golden_candle and show_small_candles)
// Priority order: double_tweezer > tweezer > pinbar > engulfers (engulfers
// orthogonal). The `and not` chains above on tweezer ensure double-tweezer
// shadows plain tweezer, and the priority below ensures plain tweezer
// shadows pinbar (pinbar fires only when neither tweezer kind triggers).
bullish_signal = show_this_candle and (bullish_double_tweezer or bullish_tweezer or (bullish_pinbar and not bullish_tweezer and not bullish_double_tweezer) or bullish_regular or bullish_floating)
bearish_signal = show_this_candle and (bearish_double_tweezer or bearish_tweezer or (bearish_pinbar and not bearish_tweezer and not bearish_double_tweezer) or bearish_regular or bearish_floating)

// ===== Per-direction signal geometry (precomputed for both the update loops
// and the capture blocks below). Computed unconditionally so they're in scope
// for the opposing-signal invalidation check during update. Values are only
// meaningful when the corresponding *_signal flag is true.
float bull_sig_high = bullish_double_tweezer ? math.max(high, nz(high[1], high), nz(high[2], high)) : bullish_tweezer ? math.max(high, nz(high[1], high)) : high
float bull_sig_low  = bullish_double_tweezer ? math.min(low, nz(low[1], low), nz(low[2], low)) : bullish_tweezer ? math.min(low, nz(low[1], low)) : low
float bull_sig_size = bullish_double_tweezer ? (candle_range + prev_candle_range + nz(prev2_candle_range, 0)) : bullish_tweezer ? (candle_range + prev_candle_range) : bullish_floating ? (bull_sig_high - bull_sig_low) : candle_range
bool  bull_sig_golden = bull_sig_size >= atr_value

float bear_sig_high = bearish_double_tweezer ? math.max(high, nz(high[1], high), nz(high[2], high)) : bearish_tweezer ? math.max(high, nz(high[1], high)) : high
float bear_sig_low  = bearish_double_tweezer ? math.min(low, nz(low[1], low), nz(low[2], low)) : bearish_tweezer ? math.min(low, nz(low[1], low)) : low
float bear_sig_size = bearish_double_tweezer ? (candle_range + prev_candle_range + nz(prev2_candle_range, 0)) : bearish_tweezer ? (candle_range + prev_candle_range) : bearish_floating ? (bear_sig_high - bear_sig_low) : candle_range
bool  bear_sig_golden = bear_sig_size >= atr_value

// Opposing-signal invalidation: a pending-or-recently-valid signal inside
// its confirm window is invalidated if an opposite-direction signal prints
// on the current bar, UNLESS the pending signal is golden and the opposer
// is not. This can flip a previously STATE_VALID signal back to
// STATE_INVALID — the rule amends the *confirmation definition* itself
// (a confirmation only counts if no opposer printed within the window).
// Per-signal application happens inside the update loops below, since the
// rule depends on each tracked signal's own `is_golden`.

// ===== Signal Persistence & State Tracking ===================================
var float[] bullish_highs = array.new_float()
var float[] bullish_lows = array.new_float()
var int[] bullish_states = array.new_int()
var int[] bullish_bars = array.new_int()
var label[] bullish_labels = array.new<label>()
var bool[] bullish_golden = array.new_bool()

var float[] bearish_highs = array.new_float()
var float[] bearish_lows = array.new_float()
var int[] bearish_states = array.new_int()
var int[] bearish_bars = array.new_int()
var label[] bearish_labels = array.new<label>()
var bool[] bearish_golden = array.new_bool()

// Persistent signal metadata for webhook embedding. These latch when a new
// signal prints (bullish or bearish) and retain their last value across all
// subsequent bars until the *next* signal overwrites them. Alertconditions
// reference them via {{plot("signal_high")}} etc. in their message= arg, so
// the webhook payload carries the *signal* geometry even when the alert
// fires on a later (confirmation) bar. signal_confirmed flips to 1.0 once
// a confirming push validates the latched signal within `confirm_bars`.
// Declared above the state loops because the loops mutate them — Pine has
// no hoisting.
var float signal_high_v       = na
var float signal_low_v        = na
var float signal_range_v      = na
var int   signal_start_time_v = na
var float signal_kind_v       = na
var float signal_golden_v     = 0.0
var float signal_atr_v        = na
var float signal_confirmed_v  = 0.0


bool bullish_just_valid = false
bool bullish_just_invalid = false
bool bearish_just_valid = false
bool bearish_just_invalid = false

// Update existing bullish signals
int bullish_index = array.size(bullish_states) - 1
while bullish_index >= 0
    int idx = bullish_index
    int state = array.get(bullish_states, idx)
    int signal_bar = array.get(bullish_bars, idx)
    float sig_high = array.get(bullish_highs, idx)
    float sig_low = array.get(bullish_lows, idx)
    label sig_label = array.get(bullish_labels, idx)
    bool is_golden = array.get(bullish_golden, idx)

    int new_state = state
    int bars_elapsed = bar_index - signal_bar

    if state == STATE_PENDING
        if bars_elapsed <= confirm_bars and high > sig_high
            new_state := STATE_VALID
        else if bars_elapsed > confirm_bars
            new_state := STATE_INVALID

    if low < sig_low
        new_state := STATE_INVALID

    // Opposing-signal invalidation inside the confirm window. Gold-protect
    // clause: skip invalidation only when the pending signal is golden and
    // the opposer is not. Applies to PENDING or recently-VALID signals; a
    // valid signal can flip back to invalid if an opposer prints in-window.
    if bars_elapsed <= confirm_bars and bearish_signal and new_state != STATE_INVALID
        if not (is_golden and not bear_sig_golden)
            new_state := STATE_INVALID

    if new_state != state
        array.set(bullish_states, idx, new_state)
        if new_state == STATE_VALID
            bullish_just_valid := true
            // Latch confirmation only if the validating signal IS the
            // currently-latched signal. Guards against a stale older
            // pending signal validating after a newer signal has
            // overwritten the latch.
            if signal_high_v == sig_high and signal_low_v == sig_low
                signal_confirmed_v := 1.0
        else if state != STATE_INVALID and new_state == STATE_INVALID
            bullish_just_invalid := true
            // Clear latched confirmation if the invalidated signal is the
            // currently-latched one — an in-window opposer retroactively
            // un-confirms it.
            if signal_high_v == sig_high and signal_low_v == sig_low
                signal_confirmed_v := 0.0

    f_apply_label_style(sig_label, true, new_state, is_golden)
    bullish_index -= 1

// Update existing bearish signals
int bearish_index = array.size(bearish_states) - 1
while bearish_index >= 0
    int idx = bearish_index
    int state = array.get(bearish_states, idx)
    int signal_bar = array.get(bearish_bars, idx)
    float sig_high = array.get(bearish_highs, idx)
    float sig_low = array.get(bearish_lows, idx)
    label sig_label = array.get(bearish_labels, idx)
    bool is_golden = array.get(bearish_golden, idx)

    int new_state = state
    int bars_elapsed = bar_index - signal_bar

    if state == STATE_PENDING
        if bars_elapsed <= confirm_bars and low < sig_low
            new_state := STATE_VALID
        else if bars_elapsed > confirm_bars
            new_state := STATE_INVALID

    if high > sig_high
        new_state := STATE_INVALID

    // Opposing-signal invalidation inside the confirm window. See bullish
    // branch for rationale.
    if bars_elapsed <= confirm_bars and bullish_signal and new_state != STATE_INVALID
        if not (is_golden and not bull_sig_golden)
            new_state := STATE_INVALID

    if new_state != state
        array.set(bearish_states, idx, new_state)
        if new_state == STATE_VALID
            bearish_just_valid := true
            // Latch confirmation only if the validating signal IS the
            // currently-latched signal (see bullish branch above).
            if signal_high_v == sig_high and signal_low_v == sig_low
                signal_confirmed_v := 1.0
        else if state != STATE_INVALID and new_state == STATE_INVALID
            bearish_just_invalid := true
            if signal_high_v == sig_high and signal_low_v == sig_low
                signal_confirmed_v := 0.0

    f_apply_label_style(sig_label, false, new_state, is_golden)
    bearish_index -= 1

// ===== Capture new signals & latch metadata ==================================
// When a new signal prints this bar, push it into the per-direction tracking
// arrays *and* overwrite the webhook-embedding latches (signal_*_v declared
// above the state loops). signal_confirmed resets to 0.0 — a fresh signal
// is unconfirmed until a later bar pushes through its extreme.
//
// Signal kind classifier — must mirror the priority in `bullish_signal` /
// `bearish_signal` above. Encoded as float per the KIND_* constants.
f_bullish_kind() =>
    bullish_double_tweezer ? KIND_DOUBLE_TWEEZER : bullish_tweezer ? KIND_TWEEZER : bullish_floating ? KIND_FLOATING_ENGULFER : bullish_regular ? KIND_REGULAR_ENGULFER : bullish_pinbar ? KIND_PINBAR : na

f_bearish_kind() =>
    bearish_double_tweezer ? KIND_DOUBLE_TWEEZER : bearish_tweezer ? KIND_TWEEZER : bearish_floating ? KIND_FLOATING_ENGULFER : bearish_regular ? KIND_REGULAR_ENGULFER : bearish_pinbar ? KIND_PINBAR : na

if bullish_signal
    int sig_start_time = bullish_double_tweezer ? nz(time[2], time) : (bullish_tweezer or bullish_regular or bullish_floating) ? nz(time[1], time) : time
    array.push(bullish_highs, bull_sig_high)
    array.push(bullish_lows, bull_sig_low)
    array.push(bullish_states, STATE_PENDING)
    array.push(bullish_bars, bar_index)
    array.push(bullish_golden, bull_sig_golden)
    label lbl = f_create_label(bar_index, bull_sig_low, true, bull_sig_golden)
    f_apply_label_style(lbl, true, STATE_PENDING, bull_sig_golden)
    array.push(bullish_labels, lbl)
    // Latch for webhook embedding (overwrites whichever signal was last).
    signal_high_v       := bull_sig_high
    signal_low_v        := bull_sig_low
    signal_range_v      := bull_sig_high - bull_sig_low
    signal_start_time_v := sig_start_time
    signal_kind_v       := f_bullish_kind()
    signal_golden_v     := bull_sig_golden ? 1.0 : 0.0
    signal_atr_v        := atr_value
    signal_confirmed_v  := 0.0

if bearish_signal
    int sig_start_time = bearish_double_tweezer ? nz(time[2], time) : (bearish_tweezer or bearish_regular or bearish_floating) ? nz(time[1], time) : time
    array.push(bearish_highs, bear_sig_high)
    array.push(bearish_lows, bear_sig_low)
    array.push(bearish_states, STATE_PENDING)
    array.push(bearish_bars, bar_index)
    array.push(bearish_golden, bear_sig_golden)
    label lbl = f_create_label(bar_index, bear_sig_high, false, bear_sig_golden)
    f_apply_label_style(lbl, false, STATE_PENDING, bear_sig_golden)
    array.push(bearish_labels, lbl)
    signal_high_v       := bear_sig_high
    signal_low_v        := bear_sig_low
    signal_range_v      := bear_sig_high - bear_sig_low
    signal_start_time_v := sig_start_time
    signal_kind_v       := f_bearish_kind()
    signal_golden_v     := bear_sig_golden ? 1.0 : 0.0
    signal_atr_v        := atr_value
    signal_confirmed_v  := 0.0

// Recent-extreme reference levels for SL anchoring. Strictly prior bars —
// `[1]` indexes the bar before the current one, so this is the highest/lowest
// of the sl_lookback bars *preceding* the signal bar. Worker scripts can read
// these as a robust SL anchor that doesn't depend on the signal candle itself.
recent_high_v = ta.highest(high[1], sl_lookback)
recent_low_v  = ta.lowest(low[1],   sl_lookback)

// Hidden plots so {{plot("signal_*")}} works in alert messages.
plot(signal_high_v,       title="signal_high",       display=display.none)
plot(signal_low_v,        title="signal_low",        display=display.none)
plot(signal_range_v,      title="signal_range",      display=display.none)
plot(signal_start_time_v, title="signal_start_time", display=display.none)
plot(signal_kind_v,       title="signal_kind",       display=display.none)
plot(signal_golden_v,     title="signal_golden",     display=display.none)
plot(signal_atr_v,        title="signal_atr",        display=display.none)
plot(signal_confirmed_v,  title="signal_confirmed",  display=display.none)
plot(recent_high_v,       title="recent_high",       display=display.none)
plot(recent_low_v,        title="recent_low",        display=display.none)

// Forward bar-close menu: the *expected* close timestamp of the bar N
// ahead on this chart's timeframe, computed against the symbol's session
// calendar so weekends and daily session breaks are skipped (a Friday
// 17:00 + 3 bars lands on the next session open, not Friday 20:00). The
// worker indexes this menu with the signed `expiry_bars` to derive a
// resting order's `cancel_at`. Negative `bars_back` projects forward
// (-1..-500); returns na on non-time-based charts, which the worker
// treats as "no bar-expiry" and falls back to not_after. Emitted as ms
// epoch (time_close returns a Unix ms int).
plot(time_close(timeframe.period, bars_back=-1), title="next_candle_timestamp_1", display=display.none)
plot(time_close(timeframe.period, bars_back=-2), title="next_candle_timestamp_2", display=display.none)
plot(time_close(timeframe.period, bars_back=-3), title="next_candle_timestamp_3", display=display.none)
plot(time_close(timeframe.period, bars_back=-4), title="next_candle_timestamp_4", display=display.none)
plot(time_close(timeframe.period, bars_back=-5), title="next_candle_timestamp_5", display=display.none)

// Trim arrays to max_signals to limit memory and computation
while array.size(bullish_states) > max_signals
    array.shift(bullish_highs)
    array.shift(bullish_lows)
    array.shift(bullish_states)
    array.shift(bullish_bars)
    array.shift(bullish_golden)
    label old_lbl = array.shift(bullish_labels)
    if not na(old_lbl)
        label.delete(old_lbl)

while array.size(bearish_states) > max_signals
    array.shift(bearish_highs)
    array.shift(bearish_lows)
    array.shift(bearish_states)
    array.shift(bearish_bars)
    array.shift(bearish_golden)
    label old_lbl = array.shift(bearish_labels)
    if not na(old_lbl)
        label.delete(old_lbl)

// ===== Alerts ================================================================
// Two alertconditions: "Long Pattern" and "Short Pattern". Each fires on BOTH
// the signal bar (signal_confirmed=0) AND the confirmation bar
// (signal_confirmed=1). The worker-side Rhai engine reads the shell vars to
// decide whether to act (golden filter, kind filter, confirmation gate,
// candle-size override, etc.).
PATTERN_MSG = 'signal_high={{plot("signal_high")}}\nsignal_low={{plot("signal_low")}}\nsignal_range={{plot("signal_range")}}\nsignal_start_time={{plot("signal_start_time")}}\nsignal_kind={{plot("signal_kind")}}\ngolden={{plot("signal_golden")}}\natr={{plot("signal_atr")}}\nsignal_confirmed={{plot("signal_confirmed")}}\nrecent_high={{plot("recent_high")}}\nrecent_low={{plot("recent_low")}}'

alertcondition(bullish_signal or bullish_just_valid, "Long Pattern",  PATTERN_MSG)
alertcondition(bearish_signal or bearish_just_valid, "Short Pattern", PATTERN_MSG)

// M/W (double-top / double-bottom) reversal trades have no prep chain and no
// pattern-detection on the chart — tv-arm bakes the path geometry into the
// signed enter intent, and the worker recomputes the stop-entry/SL/TP each bar
// close from those baked params plus live OHLC. This alertcondition is the
// per-bar-close heartbeat the M/W enter intent binds to: it fires every closed
// bar carrying only TradingView built-ins (no plots), since the worker needs
// nothing from the chart beyond the live shell. Unused by H&S, which keeps
// firing on the Long/Short Pattern conditions above.
alertcondition(true, "Every Bar Close", 'close={{close}}\nhigh={{high}}\nlow={{low}}\nopen={{open}}\ntime={{time}}')
